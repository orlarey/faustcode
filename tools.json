    {
      "name": "render_audio",
      "description": "Render the active session offline (OfflineAudioContext, bit-stable, sampleRate-configurable) with a scripted param timeline. `detail` controls the return: 'light' returns a spectrum_summary_v1 computed near the end of the render ; 'wav' writes a Float32 WAV to disk (path returned in structured content). The render does not require run_audio to be on. To capture a button press/release transition, set the button to 0 in `paramSetup` then schedule {atMs: T1, path, value: 1} and {atMs: T2, path, value: 0} in `script`. Granularity is one render quantum (~2.7 ms at 48 kHz). The returned `path` is on the filesystem of the host that runs the faustcode-mcp binary — readable by MCP clients whose model runs on the same host (Claude Code). For Claude Desktop, whose model runs in a sandbox container that does NOT share that filesystem, the file must be uploaded manually into the conversation by the user (drag-and-drop in chat) to be readable — see DEBUG.md for the rationale.",
      "stability": "stable",
      "inputSchema": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "enum": ["light", "metrics", "wav"],
            "description": "Output flavour. `light`: spectrum_summary_v1 (fast tap near 80% of the render, low cost — good for iteration). `metrics`: audio_metrics_v1 (richer analysis on the auto-detected plateau : f0 with sub-harmonic correction, harmonics dB profile, HNR, AM roughness per band, spectral features — same definitions as horn_metrics.py so a caller can run that script on a reference file and diff against this JSON). `wav`: Float32 IEEE_FLOAT WAV written to disk, path in structured content (see description for the Claude Desktop caveat)."
          },
          "durationMs": { "type": "number", "exclusiveMinimum": 0, "maximum": 30000 },
          "sampleRate": { "type": "number", "minimum": 8000, "maximum": 192000 },
          "channels": { "type": "integer", "minimum": 1, "maximum": 2 },
          "polyVoices": { "type": "integer", "enum": [0, 1, 2, 4, 8, 16, 32, 64] },
          "paramSetup": {
            "type": "object",
            "description": "Initial param values applied before t=0. Required for buttons whose press transition must be captured (start them at 0).",
            "additionalProperties": { "type": "number" }
          },
          "script": {
            "type": "array",
            "description": "Timed param events. Sorted internally by atMs. Granularity = one render quantum.",
            "maxItems": 256,
            "items": {
              "type": "object",
              "properties": {
                "atMs": { "type": "number", "minimum": 0 },
                "path": { "type": "string", "pattern": "^/" },
                "value": { "type": "number" }
              },
              "required": ["atMs", "path", "value"],
              "additionalProperties": false
            }
          },
          "metricsOptions": {
            "type": "object",
            "description": "Only meaningful when detail='metrics'. Override the metrics defaults — leave empty unless the default klaxon-ish window does not fit your sound.",
            "properties": {
              "fmin": { "type": "number", "minimum": 1, "description": "Lowest f0 candidate, Hz (default 50)." },
              "fmax": { "type": "number", "minimum": 1, "description": "Highest f0 candidate, Hz (default 400)." },
              "nHarm": { "type": "integer", "minimum": 1, "maximum": 64, "description": "Number of harmonics in harmonicsDb (default 16)." },
              "plateauFrac": { "type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "RMS fraction-of-max used to delimit the sustained portion (default 0.6)." },
              "plateauMinLenS": { "type": "number", "exclusiveMinimum": 0, "description": "Minimum plateau length in seconds (default 0.5). Plateaus shorter than this fall back to the whole buffer." },
              "plateauCapS": { "type": "number", "exclusiveMinimum": 0, "description": "Cap on the analysed plateau length in seconds (default 2.0)." },
              "roughnessBands": {
                "type": "array",
                "description": "Modulation-frequency bands, in Hz, for the roughnessDb output. Default [[5,20],[20,50],[50,100],[100,200]].",
                "items": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": { "type": "number", "minimum": 0 }
                }
              }
            },
            "additionalProperties": false
          }
        },
        "required": ["detail", "durationMs"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "oneOf": [
          {
            "properties": {
              "mime": { "const": "application/json" },
              "content": { "$ref": "#/$defs/SpectrumSummary" },
              "render": {
                "type": "object",
                "properties": {
                  "sha1": { "$ref": "#/$defs/Sha1" },
                  "fingerprint": { "type": "string" },
                  "sampleRate": { "type": "number" },
                  "channels": { "type": "integer" },
                  "durationMs": { "type": "number" },
                  "analyserFftSize": { "type": ["integer", "null"] }
                },
                "required": ["sha1", "fingerprint", "sampleRate", "channels", "durationMs"]
              }
            },
            "required": ["mime", "content", "render"]
          },
          {
            "properties": {
              "mime": { "const": "application/json" },
              "content": { "$ref": "#/$defs/AudioMetrics" },
              "render": {
                "type": "object",
                "properties": {
                  "sha1": { "$ref": "#/$defs/Sha1" },
                  "fingerprint": { "type": "string" },
                  "sampleRate": { "type": "number" },
                  "channels": { "type": "integer" },
                  "durationMs": { "type": "number" }
                },
                "required": ["sha1", "fingerprint", "sampleRate", "channels", "durationMs"]
              }
            },
            "required": ["mime", "content", "render"]
          },
          {
            "properties": {
              "mime": { "const": "audio/wav" },
              "path": {
                "type": "string",
                "description": "Absolute filesystem path to the rendered WAV. Float32 IEEE_FLOAT, readable by librosa.load(path, sr=None)."
              },
              "render": {
                "type": "object",
                "properties": {
                  "sha1": { "$ref": "#/$defs/Sha1" },
                  "fingerprint": { "type": "string" },
                  "sampleRate": { "type": "number" },
                  "channels": { "type": "integer" },
                  "durationMs": { "type": "number" },
                  "peakDbFS": { "type": "number" },
                  "rmsDbFS": { "type": "number" }
                },
                "required": ["sha1", "fingerprint", "sampleRate", "channels", "durationMs", "peakDbFS", "rmsDbFS"]
              }
            },
            "required": ["mime", "path", "render"]
          }
        ]
      }
    }
  ]
}
